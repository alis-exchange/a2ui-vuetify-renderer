{
  "name": "@alis-build/a2ui-vuetify-renderer",
  "version": "0.1.9",
  "description": "A2UI Vuetify Renderer",
  "author": "www.alisx.com",
  "type": "module",
  "main": "./dist/a2ui-vuetify-renderer.umd.cjs",
  "module": "./dist/a2ui-vuetify-renderer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/a2ui-vuetify-renderer.js",
      "require": "./dist/a2ui-vuetify-renderer.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/a2ui-vuetify-renderer.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "generate:catalog": "tsx scripts/generate-catalog.ts",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\" \"examples/**/*.{ts,vue,json}\" \"scripts/**/*.ts\""
  },
  "keywords": [
    "a2ui",
    "vuetify"
  ],
  "homepage": "https://github.com/alis-exchange/a2ui-vuetify-renderer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alis-exchange/a2ui-vuetify-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/alis-exchange/a2ui-vuetify-renderer/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "sass": "^1.98.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@a2ui/web_core": "^0.9.0",
    "vue": "^3.5.30",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@a2ui/web_core": "^0.9.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.4.0",
    "eslint-plugin-oxlint": "^1.57.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.1",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6",
    "vuetify": "^4.0.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0-beta.13"
    },
    "supportedArchitectures": {
      "os": [
        "linux",
        "darwin",
        "win32"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  },
  "style": "./dist/a2ui-vuetify-renderer.css"
}
